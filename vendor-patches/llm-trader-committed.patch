diff --git a/start.py b/start.py
index 2fe6436..618093d 100644
--- a/start.py
+++ b/start.py
@@ -131,6 +131,14 @@ class SingleInstanceLock:
     """Manages a single instance lock file to prevent multiple application instances."""
 
     def __init__(self, app_name: str = ".llm_trader.lock"):
+        # Per-instance lock: when LLM_TRADER_HOME is set (multi-instance mode)
+        # the lock file name embeds a hash of that home dir so separate
+        # instances acquire distinct locks/mutexes instead of blocking each
+        # other. Without it the original single-instance behaviour is kept.
+        home = os.environ.get("LLM_TRADER_HOME")
+        if home:
+            home_key = hashlib.sha256(str(Path(home).resolve()).encode("utf-8")).hexdigest()[:12]
+            app_name = f".llm_trader_{home_key}.lock"
         self.lock_file_path = Path.home() / app_name
         self._lock_handle: Optional[int] = None
         self._mutex_handle = None
@@ -140,7 +148,7 @@ class SingleInstanceLock:
         try:
             import ctypes
 
-            lock_key = hashlib.sha1(str(self.lock_file_path).encode("utf-8")).hexdigest()[:16]
+            lock_key = hashlib.sha256(str(self.lock_file_path).encode("utf-8")).hexdigest()[:16]
             mutex_name = f"Local\\LLMTraderSingleInstance_{lock_key}"
             kernel32 = ctypes.WinDLL("kernel32", use_last_error=True)
             handle = kernel32.CreateMutexW(None, False, mutex_name)
@@ -326,7 +334,8 @@ class CompositionRoot:
