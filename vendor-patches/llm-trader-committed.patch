         brain_dir = os.path.join(data_dir, "trading", f"brain_{safe_symbol}_{self.config.TIMEFRAME}")
         os.makedirs(brain_dir, exist_ok=True)
 
@@ -555,7 +564,8 @@ class CompositionRoot:
 
