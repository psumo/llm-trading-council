# =====================================================
# AI Trader 环境变量配置
# =====================================================
# 
# 使用说明：
# 1. 复制此文件为 .env
# 2. 填入你的真实 API 密钥
# 3. .env 文件会被 .gitignore 忽略，不会上传到 git
#
# =====================================================

# -----------------------------------------------------
# Binance API 配置
# -----------------------------------------------------
# 获取地址: https://www.binance.com/zh-CN/my/settings/api-management
# 测试网地址: https://testnet.binancefuture.com
# 
# ⚠️ 重要：建议先使用测试网！
# 
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# -----------------------------------------------------
# LLM API 配置 (支持多提供商)
# -----------------------------------------------------
# 只需配置你使用的提供商的 API Key
# 通过 LLM_PROVIDER 变量选择使用哪个提供商

# LLM 提供商选择 (默认: deepseek)
# 可选: deepseek, openai, claude, qwen, gemini, kimi, minimax, glm
LLM_PROVIDER=deepseek

# DeepSeek (默认推荐 - 低成本高性能)
# 获取地址: https://platform.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# OpenAI (可选)
# 获取地址: https://platform.openai.com
OPENAI_API_KEY=your_openai_api_key_here

# Claude / Anthropic (可选)
# 获取地址: https://console.anthropic.com
CLAUDE_API_KEY=your_claude_api_key_here

# 通义千问 Qwen (可选)
# 获取地址: https://dashscope.console.aliyun.com
QWEN_API_KEY=your_qwen_api_key_here

# Google Gemini (可选)
# 获取地址: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Kimi / Moonshot (可选)
# 获取地址: https://platform.moonshot.ai
KIMI_API_KEY=your_kimi_api_key_here

# MiniMax (可选)
# 获取地址: https://platform.minimax.io
MINIMAX_API_KEY=your_minimax_api_key_here

# GLM / 智谱 (可选)
# 获取地址: https://open.bigmodel.cn
GLM_API_KEY=your_glm_api_key_here

# 自定义 Base URL (可选 - 用于代理服务)
LLM_BASE_URL=

# -----------------------------------------------------
# Redis 配置（可选）
# -----------------------------------------------------
# 如果需要使用 Redis 缓存，请配置以下参数
#
REDIS_HOST=localhost
REDIS_PORT=6379

# -----------------------------------------------------
# Quant Data API 配置 (nofxaios)
# -----------------------------------------------------
# 用于获取机构资金流、OI数据等
#
QUANT_AUTH_TOKEN=cm_568c67eae410d912c54c

# -----------------------------------------------------
# 其他可选配置
# -----------------------------------------------------
# LOG_LEVEL=INFO
# TRADING_MODE=testnet  # testnet 或 live

# 交易币种配置 (Railway 部署默认使用 AUTO3)
# AUTO3 = AI500 智能选币 (每12小时自动选择最优2个币种)
# AI500_TOP5 = AI500 Top 5 币种
# 手动指定: BTCUSDT,ETHUSDT,SOLUSDT
TRADING_SYMBOLS=AUTO3

# -----------------------------------------------------
# Web Dashboard 安全配置
# -----------------------------------------------------
# 设置网页访问密码 (默认: admin)
WEB_PASSWORD=admin

# Database Configuration (Railway will auto-provide DATABASE_URL)
# For local development, leave empty to use SQLite
# DATABASE_URL=postgresql://user:password@localhost:5432/tradebot

# WebSocket Configuration
# Set to 'false' to disable WebSocket and use REST API only
# USE_WEBSOCKET=true
